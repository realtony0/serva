rules_version = '2';

/**
 * Règles de sécurité Firestore pour SERVA
 *
 * Principes :
 * - Les clients (non authentifiés) ne peuvent que lire les menus/restaurants et créer des commandes
 * - Les utilisateurs authentifiés ne peuvent modifier que les données de LEUR restaurant
 * - Les admins ont un accès élargi via leur profil user_profiles
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // FONCTIONS UTILITAIRES
    // ============================================

    // Vérifie que l'utilisateur est authentifié
    function isAuthenticated() {
      return request.auth != null;
    }

    // Récupère le profil utilisateur (admin ou restaurant)
    function getUserProfile() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    // Vérifie que l'utilisateur est un admin
    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid))
        && getUserProfile().role == "admin";
    }

    // Récupère le restaurant_user pour vérifier le rôle dans un restaurant
    function getRestaurantUser(restaurantId) {
      return get(/databases/$(database)/documents/restaurant_users/$(request.auth.uid)).data;
    }

    // Vérifie que l'utilisateur appartient à ce restaurant
    function isRestaurantMember(restaurantId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/restaurant_users/$(request.auth.uid))
        && getRestaurantUser(restaurantId).restaurantId == restaurantId;
    }

    // Vérifie que l'utilisateur est owner ou manager du restaurant
    function isRestaurantManager(restaurantId) {
      return isRestaurantMember(restaurantId)
        && getRestaurantUser(restaurantId).role in ["owner", "manager"];
    }

    // Vérifie que l'utilisateur est le owner du restaurant
    function isRestaurantOwner(restaurantId) {
      return isRestaurantMember(restaurantId)
        && getRestaurantUser(restaurantId).role == "owner";
    }

    // ============================================
    // RESTAURANTS
    // ============================================
    match /restaurants/{restaurantId} {
      // Lecture publique (les clients scannent un QR et voient le restaurant)
      allow read: if true;

      // Création : uniquement les admins
      allow create: if isAdmin();

      // Modification : owner ou manager du restaurant, ou admin
      allow update: if isAdmin() || isRestaurantManager(restaurantId);

      // Suppression : uniquement admin
      allow delete: if isAdmin();
    }

    // ============================================
    // TABLES
    // ============================================
    match /tables/{tableId} {
      // Lecture publique (les clients ont besoin de voir leur table)
      allow read: if true;

      // Écriture : owner/manager du restaurant concerné, ou admin
      allow create: if isAdmin()
        || (isAuthenticated()
            && request.resource.data.restaurantId is string
            && isRestaurantManager(request.resource.data.restaurantId));

      allow update: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantManager(resource.data.restaurantId));

      allow delete: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantManager(resource.data.restaurantId));
    }

    // ============================================
    // USER PROFILES (admin, restaurant)
    // ============================================
    match /user_profiles/{userId} {
      // Un utilisateur peut lire son propre profil, les admins peuvent tout lire
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());

      // Création : uniquement les admins (ils assignent les rôles)
      allow create: if isAdmin();

      // Modification : l'utilisateur lui-même (sauf le rôle) ou un admin
      allow update: if isAdmin()
        || (isAuthenticated()
            && request.auth.uid == userId
            && request.resource.data.role == resource.data.role);

      // Suppression : uniquement admin
      allow delete: if isAdmin();
    }

    // ============================================
    // RESTAURANT USERS (rôles par restaurant)
    // ============================================
    match /restaurant_users/{userId} {
      // Lecture : le user lui-même, le owner/manager du restaurant, ou un admin
      allow read: if isAuthenticated()
        && (request.auth.uid == userId
            || isAdmin()
            || (resource.data.restaurantId is string
                && isRestaurantManager(resource.data.restaurantId)));

      // Création : owner du restaurant ou admin
      allow create: if isAdmin()
        || (isAuthenticated()
            && request.resource.data.restaurantId is string
            && isRestaurantOwner(request.resource.data.restaurantId));

      // Modification : owner du restaurant ou admin
      allow update: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantOwner(resource.data.restaurantId));

      // Suppression : owner du restaurant ou admin
      allow delete: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantOwner(resource.data.restaurantId));
    }

    // ============================================
    // MENU - CATEGORIES
    // ============================================
    match /menu_categories/{categoryId} {
      // Lecture publique (les clients voient le menu)
      allow read: if true;

      // Écriture : owner/manager du restaurant, ou admin
      allow create: if isAdmin()
        || (isAuthenticated()
            && request.resource.data.restaurantId is string
            && isRestaurantManager(request.resource.data.restaurantId));

      allow update: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantManager(resource.data.restaurantId));

      allow delete: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantManager(resource.data.restaurantId));
    }

    // ============================================
    // MENU - TYPES
    // ============================================
    match /menu_types/{typeId} {
      // Lecture publique
      allow read: if true;

      // Écriture : owner/manager du restaurant, ou admin
      allow create: if isAdmin()
        || (isAuthenticated()
            && request.resource.data.restaurantId is string
            && isRestaurantManager(request.resource.data.restaurantId));

      allow update: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantManager(resource.data.restaurantId));

      allow delete: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantManager(resource.data.restaurantId));
    }

    // ============================================
    // MENU - PRODUCTS
    // ============================================
    match /menu_products/{productId} {
      // Lecture publique
      allow read: if true;

      // Écriture : owner/manager du restaurant, ou admin
      allow create: if isAdmin()
        || (isAuthenticated()
            && request.resource.data.restaurantId is string
            && isRestaurantManager(request.resource.data.restaurantId));

      allow update: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantManager(resource.data.restaurantId));

      allow delete: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantManager(resource.data.restaurantId));
    }

    // ============================================
    // ORDERS (COMMANDES)
    // ============================================
    match /orders/{orderId} {
      // Lecture : membres du restaurant concerné, ou admin
      // Les clients lisent via leur orderId stocké en localStorage
      allow read: if true;

      // Création : tout le monde (les clients passent commande sans auth)
      // Validation stricte des données
      allow create: if
        request.resource.data.keys().hasAll(['restaurantId', 'tableId', 'items', 'total', 'status', 'createdAt', 'updatedAt'])
        && request.resource.data.restaurantId is string
        && request.resource.data.restaurantId.size() > 0
        && request.resource.data.tableId is string
        && request.resource.data.tableId.size() > 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 50
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.total <= 10000000
        && request.resource.data.status == "pending";

      // Mise à jour : uniquement le staff du restaurant (changer le statut)
      allow update: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantMember(resource.data.restaurantId)
            && request.resource.data.restaurantId == resource.data.restaurantId
            && request.resource.data.tableId == resource.data.tableId);

      // Suppression : owner/manager ou admin uniquement
      allow delete: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantManager(resource.data.restaurantId));
    }

    // ============================================
    // SERVICE REQUESTS (appel serveur, addition)
    // ============================================
    match /service_requests/{requestId} {
      // Lecture : membres du restaurant, ou admin
      allow read: if true;

      // Création : tout le monde (les clients appellent le serveur sans auth)
      allow create: if
        request.resource.data.keys().hasAll(['restaurantId', 'tableId', 'tableNumber', 'type', 'status', 'createdAt', 'updatedAt'])
        && request.resource.data.restaurantId is string
        && request.resource.data.restaurantId.size() > 0
        && request.resource.data.tableId is string
        && request.resource.data.type in ["server", "bill"]
        && request.resource.data.status == "pending";

      // Mise à jour : staff du restaurant (marquer comme traité)
      allow update: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantMember(resource.data.restaurantId));

      // Suppression : manager/owner ou admin
      allow delete: if isAdmin()
        || (isAuthenticated()
            && resource.data.restaurantId is string
            && isRestaurantManager(resource.data.restaurantId));
    }

    // ============================================
    // FEEDBACK (avis clients)
    // ============================================
    match /feedback/{feedbackId} {
      // Lecture : membres du restaurant, ou admin
      allow read: if isAuthenticated();

      // Création : tout le monde (les clients laissent un avis sans auth)
      allow create: if
        request.resource.data.keys().hasAll(['restaurantId', 'rating', 'createdAt'])
        && request.resource.data.restaurantId is string
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;

      // Pas de modification ni suppression des avis
      allow update, delete: if isAdmin();
    }

    // ============================================
    // REGISTRATION REQUESTS (demandes d'inscription)
    // ============================================
    match /registration_requests/{requestId} {
      // Lecture : uniquement les admins
      allow read: if isAdmin();

      // Création : tout le monde (formulaire public, sans auth)
      allow create: if
        request.resource.data.keys().hasAll(['restaurantName', 'ownerName', 'email', 'phone', 'city', 'estimatedTables', 'status', 'createdAt', 'updatedAt'])
        && request.resource.data.restaurantName is string
        && request.resource.data.restaurantName.size() > 0
        && request.resource.data.ownerName is string
        && request.resource.data.ownerName.size() > 0
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.phone is string
        && request.resource.data.phone.size() >= 8
        && request.resource.data.estimatedTables is number
        && request.resource.data.estimatedTables >= 1
        && request.resource.data.estimatedTables <= 500
        && request.resource.data.status == "pending";

      // Modification : uniquement les admins (changer le statut)
      allow update: if isAdmin();

      // Suppression : uniquement les admins
      allow delete: if isAdmin();
    }

    // ============================================
    // RÈGLE PAR DÉFAUT — Tout bloquer
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
