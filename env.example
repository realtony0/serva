# Variables d'environnement Firebase
# Copiez ce fichier en .env.local et remplissez les valeurs depuis votre console Firebase

# Firebase Configuration
# Obtenez ces valeurs dans : Firebase Console > Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# API (optionnel)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# URL du site en production (pour les QR codes)
# Exemple: https://votre-domaine.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
